# ==============================================================================
# Python API -- Environment Variables
# Copy this file to .env and fill in your values.
# ==============================================================================

# -- Entra ID (Azure AD) -------------------------------------------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# -- Azure AI Foundry ----------------------------------------------------------
FOUNDRY_PROJECT_ENDPOINT=https://<workspace>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL_DEPLOYMENT_NAME=chat4o
FOUNDRY_AGENT_NAME=CapMarketAgent
FOUNDRY_API_VERSION=2025-05-15-preview
FOUNDRY_RESPONSE_TIMEOUT_SECONDS=180

# -- Per-agent model deployments -----------------------------------------------
# Meeting Intelligence agents
AGENT_TRANSCRIPTION_MODEL=chat4o
AGENT_SENTIMENT_MODEL=chat4o
AGENT_PROFILE_MODEL=chat41
AGENT_RECOMMENDATION_MODEL=chato4mini
AGENT_SUMMARY_MODEL=chat41
AGENT_PII_MODEL=chat4o

# Advisory & Communication agents
AGENT_ADVISORY_MODEL=chato4mini
AGENT_TAX_MODEL=chato4mini
AGENT_COMMUNICATION_MODEL=chat41
AGENT_NEWS_MODEL=chat41

# Portfolio Intelligence agents
AGENT_PORTFOLIO_MODEL=chato1
AGENT_BACKTESTING_MODEL=chato4mini
AGENT_REBALANCE_MODEL=chat41nano

# -- Azure OpenAI --------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<account>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=chat4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=embedding

# -- Azure Blob Storage --------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_BLOB_STORAGE_NAME=
AZURE_STORAGE_CONTAINER=capmarkets

# -- Azure Cosmos DB -----------------------------------------------------------
COSMOSDB_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_DB_DATABASE=capmarkets
COSMOS_DB_CONTAINER=portfolio
# Optional master key -- leave blank to use ClientSecretCredential (RBAC)
COSMOS_DB_KEY=

# -- Azure AI Search -----------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX_CLIENTS=cmclients
AZURE_SEARCH_INDEX_MEETINGS=cmmeetings
AZURE_SEARCH_INDEX_DOCUMENTS=cmdocuments

# -- Bing Grounding (link a Bing Search resource to AI Foundry) ----------------
BING_GROUNDING_CONNECTION_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>/connections/<connection>
BING_GROUNDING_CONNECTION_NAME=

# -- Azure Speech Services -----------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=en-US
ENABLE_SPEAKER_DIARIZATION=true

# -- Azure Language Service (PII detection) ------------------------------------
AZURE_LANGUAGE_KEY=
AZURE_LANGUAGE_ENDPOINT=https://<account>.cognitiveservices.azure.com/

# -- Application Insights (optional) ------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# -- CORS ----------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
